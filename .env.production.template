# ============================================================================
# SignalixAI Backend - Production Environment Variables
# ============================================================================
# INSTRUCTIONS:
# 1. Copy this file to .env
# 2. Fill in all the API keys with your actual values
# 3. Never commit .env to git (it's in .gitignore)
# ============================================================================

# ============================================================================
# DATABASE & CACHE (Already Configured)
# ============================================================================

# PostgreSQL Database (Supabase)
# Get from: https://supabase.com/dashboard/project/_/settings/database
DATABASE_URL=postgresql://postgres.xxx:password@aws-0-region.pooler.supabase.com:6543/postgres

# Redis Cache (Upstash)
# Get from: https://console.upstash.com/redis
REDIS_URL=rediss://default:password@region.upstash.io:6379

# ============================================================================
# MARKET DATA - Angel One API
# ============================================================================
# Signup: https://smartapi.angelbroking.com/
# Docs: https://smartapi.angelbroking.com/docs

MARKET_DATA_PROVIDER=angelone

# Angel One API Credentials
ANGEL_ONE_API_KEY=PASTE_YOUR_ANGEL_ONE_API_KEY_HERE
ANGEL_ONE_CLIENT_ID=PASTE_YOUR_CLIENT_ID_HERE
ANGEL_ONE_PASSWORD=PASTE_YOUR_PASSWORD_HERE
ANGEL_ONE_TOTP_SECRET=PASTE_YOUR_TOTP_SECRET_HERE

# ============================================================================
# NEWS DATA - Yahoo Finance
# ============================================================================
# Free API, no key required
# Uses yfinance Python library

NEWS_PROVIDER=yahoo_finance
NEWS_ENABLED=true

# ============================================================================
# AI/LLM - Anthropic Claude
# ============================================================================
# Signup: https://console.anthropic.com/
# Get API Key: https://console.anthropic.com/settings/keys

ANTHROPIC_API_KEY=PASTE_YOUR_ANTHROPIC_API_KEY_HERE
# Format: sk-ant-api03-xxxxx

# LLM Configuration
DEFAULT_LLM_PROVIDER=anthropic
DEFAULT_MODEL=claude-3-5-sonnet-20241022
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096

# ============================================================================
# EMAIL - SendGrid
# ============================================================================
# Signup: https://signup.sendgrid.com/
# Get API Key: https://app.sendgrid.com/settings/api_keys

EMAIL_PROVIDER=sendgrid
SENDGRID_API_KEY=PASTE_YOUR_SENDGRID_API_KEY_HERE
# Format: SG.xxxxx

# Email Configuration
EMAIL_FROM=noreply@yourdomain.com
EMAIL_FROM_NAME=SignalixAI
EMAIL_REPLY_TO=support@yourdomain.com

# ============================================================================
# WHATSAPP - Twilio
# ============================================================================
# Signup: https://www.twilio.com/try-twilio
# Get credentials: https://console.twilio.com/

WHATSAPP_ENABLED=true
WHATSAPP_PROVIDER=twilio

# Twilio Credentials
TWILIO_ACCOUNT_SID=PASTE_YOUR_TWILIO_ACCOUNT_SID_HERE
# Format: ACxxxxx

TWILIO_AUTH_TOKEN=PASTE_YOUR_TWILIO_AUTH_TOKEN_HERE

TWILIO_WHATSAPP_NUMBER=PASTE_YOUR_TWILIO_WHATSAPP_NUMBER_HERE
# Format: whatsapp:+14155238886

# ============================================================================
# PAYMENT - Razorpay
# ============================================================================
# Signup: https://dashboard.razorpay.com/signup
# Get keys: https://dashboard.razorpay.com/app/keys

PAYMENT_PROVIDER=razorpay

# Razorpay Credentials
RAZORPAY_KEY_ID=PASTE_YOUR_RAZORPAY_KEY_ID_HERE
# Format: rzp_live_xxxxx (production) or rzp_test_xxxxx (testing)

RAZORPAY_KEY_SECRET=PASTE_YOUR_RAZORPAY_KEY_SECRET_HERE

RAZORPAY_WEBHOOK_SECRET=PASTE_YOUR_RAZORPAY_WEBHOOK_SECRET_HERE
# Get from: https://dashboard.razorpay.com/app/webhooks

# ============================================================================
# ERROR TRACKING - Sentry
# ============================================================================
# Signup: https://sentry.io/signup/
# Get DSN: https://sentry.io/settings/projects/

SENTRY_DSN=https://9692f3d09fde5994267b86ebd2d65284@o4511284828504064.ingest.us.sentry.io/4511284831846400
# Format: https://xxxxx@o123456.ingest.sentry.io/123456

SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_ENABLED=true

# ============================================================================
# UPTIME MONITORING - UptimeRobot
# ============================================================================
# Signup: https://uptimerobot.com/signUp
# Note: UptimeRobot doesn't need API key in backend
# Configure monitors in their dashboard

UPTIME_MONITORING_ENABLED=true

# ============================================================================
# CDN - Cloudflare
# ============================================================================
# Signup: https://dash.cloudflare.com/sign-up
# Note: Cloudflare is configured via DNS, not API keys in backend
# Add your domain to Cloudflare and update nameservers

CLOUDFLARE_ENABLED=true

# Optional: Cloudflare API for programmatic access
CLOUDFLARE_API_KEY=PASTE_YOUR_CLOUDFLARE_API_KEY_HERE_IF_NEEDED
CLOUDFLARE_ZONE_ID=PASTE_YOUR_ZONE_ID_HERE_IF_NEEDED

# ============================================================================
# SECURITY & JWT
# ============================================================================

# JWT Secret (Generate a strong random string)
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=PASTE_YOUR_JWT_SECRET_KEY_HERE_MINIMUM_32_CHARACTERS
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# ============================================================================
# CORS & SECURITY
# ============================================================================

# Allowed Origins (comma-separated)
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com,http://localhost:3000

# Security Headers
ENABLE_CORS=true
ENABLE_RATE_LIMITING=true
RATE_LIMIT_PER_MINUTE=60

# ============================================================================
# APPLICATION CONFIGURATION
# ============================================================================

# Environment
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO

# Application
APP_NAME=SignalixAI
APP_VERSION=1.0.0
APP_URL=https://yourdomain.com
API_URL=https://api.yourdomain.com

# ============================================================================
# OPTIONAL: ADDITIONAL SERVICES
# ============================================================================

# Google Analytics (Optional)
GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX

# Mixpanel (Optional)
MIXPANEL_TOKEN=your_mixpanel_token_here

# Slack Notifications (Optional)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz

# ============================================================================
# DEVELOPMENT OVERRIDES (Remove in production)
# ============================================================================

# Uncomment for local development
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/signalixai
# REDIS_URL=redis://localhost:6379
# ENVIRONMENT=development
# DEBUG=true
# ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ============================================================================
# END OF CONFIGURATION
# ============================================================================
