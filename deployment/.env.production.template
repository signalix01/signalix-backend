# Production Environment Variables Template
# Copy this file to .env.production and fill in the values

# Environment
ENVIRONMENT=production

# Database Configuration
DATABASE_URL=postgresql://postgres:PASSWORD@HOST:5432/signalix
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=signalix

# Redis Configuration
REDIS_URL=redis://:PASSWORD@HOST:6379/0
REDIS_PASSWORD=CHANGE_ME

# Celery Configuration
CELERY_BROKER_URL=redis://:PASSWORD@HOST:6379/0
CELERY_RESULT_BACKEND=redis://:PASSWORD@HOST:6379/1

# JWT Configuration
JWT_SECRET=CHANGE_ME_TO_RANDOM_256_BIT_STRING
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# API Keys - External Services
GLASSNODE_API_KEY=your_glassnode_api_key_here
POLYGON_API_KEY=your_polygon_api_key_here
XAI_API_KEY=your_xai_api_key_here
DEEPSEEK_API_KEY=your_deepseek_api_key_here
GOOGLE_API_KEY=your_google_gemini_api_key_here
UNUSUAL_WHALES_API_KEY=your_unusual_whales_api_key_here

# Broker API Keys
ANGEL_ONE_API_KEY=your_angel_one_api_key_here
ANGEL_ONE_API_SECRET=your_angel_one_api_secret_here
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here
OANDA_API_KEY=your_oanda_api_key_here
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_API_SECRET=your_alpaca_api_secret_here

# OpenAlgo Configuration
OPENALGO_BASE_URL=https://your-openalgo-instance.com
OPENALGO_API_KEY=your_openalgo_api_key_here

# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here

# SQS Queue URLs (will be populated by CDK deployment)
SQS_BACKTEST_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/ACCOUNT_ID/backtest-queue
SQS_ALERT_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/ACCOUNT_ID/alert-queue.fifo
SQS_SCREENING_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/ACCOUNT_ID/screening-queue

# Notification Services
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
SENDGRID_API_KEY=your_sendgrid_api_key_here
SENDGRID_FROM_EMAIL=noreply@signalix.com
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
FCM_SERVER_KEY=your_fcm_server_key_here

# Service URLs (internal)
ALGO_BUILDER_URL=http://algo-builder:8000
BACKTESTING_URL=http://backtesting:8001
SCREENING_URL=http://screening:8002
ALERTS_URL=http://alerts:8003

# Logging
LOG_LEVEL=INFO
SENTRY_DSN=your_sentry_dsn_here

# Rate Limiting
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_PER_HOUR=1000

# CORS Origins
CORS_ORIGINS=https://app.signalix.com,https://www.signalix.com

# Feature Flags
ENABLE_PAPER_TRADING=true
ENABLE_LIVE_TRADING=true
ENABLE_AI_SCREENING=true
ENABLE_WHALE_TRACKING=true

# Performance Tuning
UVICORN_WORKERS=4
CELERY_WORKER_CONCURRENCY=4
MAX_CONCURRENT_BACKTESTS_FREE=1
MAX_CONCURRENT_BACKTESTS_PRO=5
MAX_CONCURRENT_BACKTESTS_ENTERPRISE=unlimited

# Data Retention (days)
ANOMALY_EVENTS_RETENTION_FREE=30
ANOMALY_EVENTS_RETENTION_PRO=90
SCREENING_RESULTS_RETENTION=7
BACKTEST_RESULTS_RETENTION=365

# Monitoring
ENABLE_METRICS=true
METRICS_PORT=9090
ENABLE_TRACING=true
JAEGER_AGENT_HOST=localhost
JAEGER_AGENT_PORT=6831
