# Application
APP_NAME=SignalixAI AI
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=True

# API
API_V1_PREFIX=/api/v1
ALLOWED_ORIGINS=http://localhost:3000,https://signalixai.com

# Service URLs (for inter-service communication)
AUTH_SERVICE_URL=http://localhost:8000
USER_SERVICE_URL=http://localhost:8001
ANALYSIS_SERVICE_URL=http://localhost:8002
MARKET_DATA_SERVICE_URL=http://localhost:8003
PORTFOLIO_SERVICE_URL=http://localhost:8004
NOTIFICATION_SERVICE_URL=http://localhost:8005
SUBSCRIPTION_SERVICE_URL=http://localhost:8006
ANALYTICS_SERVICE_URL=http://localhost:8007
BACKTEST_SERVICE_URL=http://localhost:8008

# Database (Supabase PostgreSQL)
DATABASE_URL=postgresql+asyncpg://postgres:YOUR_PASSWORD_HERE@db.YOUR_PROJECT.supabase.co:5432/postgres
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# Redis (Upstash)
REDIS_URL=redis://default:YOUR_PASSWORD_HERE@YOUR_REGION.upstash.io:6379
REDIS_MAX_CONNECTIONS=50

# JWT
JWT_SECRET_KEY=your-secret-key-change-this-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Security
BCRYPT_ROUNDS=12
RATE_LIMIT_PER_MINUTE=60

# LLM API Keys
ANTHROPIC_API_KEY=sk-ant-xxx
GOOGLE_API_KEY=AIzaSyxxx
OPENAI_API_KEY=sk-xxx
XAI_API_KEY=xai-xxx
DEEPSEEK_API_KEY=sk-xxx
MISTRAL_API_KEY=xxx

# External Services
SENDGRID_API_KEY=SG.xxx
TWILIO_ACCOUNT_SID=ACxxx
TWILIO_AUTH_TOKEN=xxx
WHATSAPP_API_KEY=xxx
TELEGRAM_BOT_TOKEN=xxx

# Payment Gateways
RAZORPAY_KEY_ID=rzp_test_xxx
RAZORPAY_KEY_SECRET=xxx
STRIPE_API_KEY=sk_test_xxx

# Broker APIs
ZERODHA_API_KEY=xxx
ZERODHA_API_SECRET=xxx
ANGEL_ONE_API_KEY=xxx
UPSTOX_API_KEY=xxx

# Monitoring
SENTRY_DSN=https://your_sentry_dsn_here@o123.ingest.sentry.io/123
PROMETHEUS_PORT=9090

# Feature Flags
ENABLE_WHATSAPP=True
ENABLE_TELEGRAM=True
ENABLE_SMS=True
ENABLE_BEHAVIORAL_SIGNALS=True
ENABLE_FEEDBACK_LOOP=True

# Data Residency
DATA_REGION=ap-south-1

# Behavioral Signals (Tier 3)
BEHAVIORAL_SIGNALS_LOOKBACK_DAYS=90
BEHAVIORAL_SIGNALS_MIN_TRADES=5
BEHAVIORAL_SIGNALS_UPDATE_SCHEDULE=0 2 * * *  # Daily at 2 AM

# Feedback Loop
FEEDBACK_PROMPT_DELAY_HOURS=24
FEEDBACK_REMINDER_ENABLED=True

